From d96226cae37ad9bb7e09b1c4b54770d39a074e51 Mon Sep 17 00:00:00 2001
From: Tim Stahlhut <stahta01@gmail.com>
Date: Tue, 28 Apr 2026 02:05:10 -0400
Subject: Add MSYS cmake guards

---
 CMakeLists.txt          | 26 ++++++++++++++++----------
 cmake/sdlplatform.cmake |  2 +-
 test/CMakeLists.txt     |  4 ++--
 3 files changed, 19 insertions(+), 13 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index ff79c018a..38fcffe76 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1033,7 +1033,7 @@ endif()
 # TODO: Can't deactivate on FreeBSD? w/o LIBC, SDL_stdinc.h can't define
 # anything.
 if(SDL_LIBC)
-  if(WINDOWS AND NOT MINGW)
+  if(WINDOWS AND NOT (MINGW OR MSYS))
     set(HAVE_LIBC TRUE)
     check_include_file(stdint.h HAVE_STDINT_H)
     foreach(_HEADER stdio.h string.h wchar.h ctype.h math.h limits.h)
@@ -1233,7 +1233,7 @@ if(SDL_AUDIO)
   endif()
 endif()
 
-if(UNIX OR APPLE)
+if(UNIX AND NOT MSYS OR APPLE)
   # Relevant for Unix/Darwin only
   set(DYNAPI_NEEDS_DLOPEN 1)
   CheckDLOPEN()
@@ -1479,7 +1479,7 @@ elseif(EMSCRIPTEN)
   CheckPTHREAD()
   CheckLibUnwind()
 
-elseif(UNIX AND NOT APPLE AND NOT RISCOS AND NOT HAIKU)
+elseif(UNIX AND NOT MSYS AND NOT APPLE AND NOT RISCOS AND NOT HAIKU)
   if(SDL_AUDIO)
     if(SYSV5 OR SOLARIS OR HPUX)
         # Newer Solaris-based systems, like OpenIndiana, don't have this interface anymore. Check for the header first.
@@ -1793,7 +1793,7 @@ elseif(UNIX AND NOT APPLE AND NOT RISCOS AND NOT HAIKU)
     set(HAVE_VSNPRINTF 0)
     set(USE_POSIX_SPAWN 1)
   endif()
-elseif(WINDOWS)
+elseif(WINDOWS OR MSYS)
   find_program(WINDRES windres)
 
   check_c_source_compiles("
@@ -1824,7 +1824,7 @@ elseif(WINDOWS)
     if(DEFINED MSVC_VERSION AND NOT ${MSVC_VERSION} LESS 1700)
         set(USE_WINSDK_DIRECTX TRUE)
     endif()
-    if(NOT MINGW AND NOT USE_WINSDK_DIRECTX)
+    if(NOT (MINGW OR MSYS) AND NOT USE_WINSDK_DIRECTX)
       if("$ENV{DXSDK_DIR}" STREQUAL "")
         message_error("DIRECTX requires the \$DXSDK_DIR environment variable to be set")
       endif()
@@ -2052,7 +2052,7 @@ elseif(WINDOWS)
     file(GLOB JOYSTICK_SOURCES ${SDL2_SOURCE_DIR}/src/joystick/windows/*.c)
     list(APPEND SOURCE_FILES ${JOYSTICK_SOURCES})
 
-    if(NOT WINDOWS_STORE)
+    if(NOT WINDOWS_STORE AND NOT MSYS)
       set(SDL_JOYSTICK_RAWINPUT 1)
     endif()
     if(HAVE_DINPUT_H)
@@ -2091,12 +2091,18 @@ elseif(WINDOWS)
   enable_language(RC)
   file(GLOB VERSION_SOURCES ${SDL2_SOURCE_DIR}/src/main/windows/*.rc)
   file(GLOB SDLMAIN_SOURCES ${SDL2_SOURCE_DIR}/src/main/windows/*.c)
-  if(MINGW OR CYGWIN)
+  if(MINGW OR MSYS OR CYGWIN)
     if(NOT SDL2_DISABLE_SDL2MAIN)
       list(APPEND SDL_CFLAGS "-Dmain=SDL_main")
       list(INSERT SDL_LIBS 0 "-lSDL2main")
     endif(NOT SDL2_DISABLE_SDL2MAIN)
-    list(INSERT SDL_LIBS 0 "-lmingw32" "-mwindows")
+    if(MSYS)
+      list(INSERT SDL_LIBS 0 "-lmsys-2.0" "-mwindows")
+    elseif(CYGWIN)
+      list(INSERT SDL_LIBS 0 "-lcygwin" "-mwindows")
+    else()
+      list(INSERT SDL_LIBS 0 "-lmingw32" "-mwindows")
+    endif()
   endif()
 
 elseif(APPLE)
@@ -3744,11 +3750,11 @@ if(NOT SDL2_DISABLE_INSTALL)
     install(FILES ${SDL2_BINARY_DIR}/sdl2.pc
             DESTINATION "${CMAKE_INSTALL_LIBDIR}/pkgconfig")
   endif()
-  if(NOT (WINDOWS OR CYGWIN) OR MINGW)
+  if(NOT (WINDOWS OR CYGWIN) OR MINGW OR MSYS)
     if(SDL_SHARED)
       set(SOEXT ${CMAKE_SHARED_LIBRARY_SUFFIX}) # ".so", ".dylib", etc.
       get_target_property(SONAME SDL2 OUTPUT_NAME)
-      if(NOT ANDROID AND NOT MINGW AND NOT OS2)
+      if(NOT ANDROID AND NOT MINGW AND NOT MSYS AND NOT OS2)
           install(CODE "
             execute_process(COMMAND ${CMAKE_COMMAND} -E create_symlink
               \"lib${SONAME}${SOPOSTFIX}${SOEXT}\" \"libSDL2${SOPOSTFIX}${SOEXT}\"
diff --git a/cmake/sdlplatform.cmake b/cmake/sdlplatform.cmake
index d0d57671e..15509bcde 100644
--- a/cmake/sdlplatform.cmake
+++ b/cmake/sdlplatform.cmake
@@ -1,7 +1,7 @@
 macro(SDL_DetectCMakePlatform)
   set(SDL_CMAKE_PLATFORM )
   # Get the platform
-  if(WIN32)
+  if(WIN32 OR MSYS)
     set(SDL_CMAKE_PLATFORM WINDOWS)
   elseif(UNIX AND NOT APPLE)
     if(CMAKE_SYSTEM_NAME MATCHES ".*Linux")
diff --git a/test/CMakeLists.txt b/test/CMakeLists.txt
index 288645d73..75a6e4f4a 100644
--- a/test/CMakeLists.txt
+++ b/test/CMakeLists.txt
@@ -250,9 +250,9 @@ else()
     sdltest_link_librararies(SDL2::SDL2test SDL2::SDL2-static)
 endif()
 
-if(WINDOWS)
+if(WINDOWS OR MSYS)
     # mingw32 must come before SDL2main to link successfully
-    if(MINGW OR CYGWIN)
+    if(MINGW OR MSYS OR CYGWIN)
         sdltest_link_librararies(mingw32)
     endif()
 
-- 
2.53.0.windows.2

