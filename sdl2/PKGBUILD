# contributer: Zach Bacon <zachbacon@budgiemedia.rocks>

_realname=SDL2
pkgname=sdl2
pkgver=2.32.10
pkgrel=2
pkgdesc="A library for portable low-level access to a video framebuffer, audio output, mouse, and keyboard (Version 2)"
arch=('i686' 'x86_64')
url="https://www.libsdl.org"
license=('Zlib')
depends=()
makedepends=('cmake' 'ninja' 'autotools' 'gcc')
source=("https://github.com/libsdl-org/SDL/releases/download/release-${pkgver}/SDL2-${pkgver}.tar.gz"{,.sig}
        '001-Add-MSYS-cmake-guards.patch')
sha512sums=('b67ebdb46bc3b41c974113937e15445e47a6e115692761e2812c3965e85b9ca4d804633de6369fa3dd36cc77f5d08655570c1707245b2c46f88114aa3238fd1b'
            'SKIP'
            '32d8d2d8b7e8fea83d1be866e9d002f361e0f953c09f37d5bba9f1dee8ab10153fdf16f25d1452161331b573d9a97631916534efd92e4048e90ea025626faa04')
validpgpkeys=('1528635D8053A57F77D1E08630A59377A7763BE6') # Sam Lantinga

prepare() {
  cd SDL2-${pkgver}

  patch -p1 -i "${srcdir}"/001-Add-MSYS-cmake-guards.patch
}

build() {
  [[ -d "build-${MSYSTEM_CARCH}" ]] && rm -rf "build-${MSYSTEM_CARCH}"
  mkdir -p "${srcdir}/build-${MSYSTEM_CARCH}"
  cd "${srcdir}/build-${MSYSTEM_CARCH}"

  ${MSYSTEM_PREFIX}/bin/cmake.exe \
    -GNinja \
    -DCMAKE_INSTALL_PREFIX=${MSYSTEM_PREFIX} \
    -DCMAKE_BUILD_TYPE=Release \
    -DSDL_VULKAN=ON \
    -DSDL_TEST=ON \
    ../${_realname}-${pkgver}

  ${MSYSTEM_PREFIX}/bin/cmake --build .
}

package() {
  cd "${srcdir}/build-${MSYSTEM_CARCH}"

  DESTDIR="${pkgdir}" ${MSYSTEM_PREFIX}/bin/cmake --install .

  install -Dm644 ../SDL2-${pkgver}/LICENSE.txt "$pkgdir${MSYSTEM_PREFIX}/share/licenses/$pkgname/LICENSE"
}

