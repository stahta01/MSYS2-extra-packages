# Contributor: Renato Silva <br.renatosilva@gmail.com>

_realname=drmingw
pkgbase="${_realname}"
pkgname=(${_realname})
pkgver=0.9.11
pkgrel=2
pkgdesc="Just-in-Time (JIT) debugger"
arch=('i686' 'x86_64')
url='https://github.com/jrfonseca/drmingw'
msys2_repository_url='https://github.com/jrfonseca/drmingw'
license=('spdx:LGPL-2.1-or-later')
makedepends=('cmake' 'ninja' 'git')
if [[ "${CARCH}" == 'i686' ]]; then
  makedepends+=('mingw-w64-mingw32-gcc')
  makedepends+=('mingw-w64-mingw32-binutils')
else
  makedepends+=('mingw-w64-ucrt64-gcc')
  makedepends+=('mingw-w64-ucrt64-binutils')
fi
options=(!strip)
source=("${_realname}::git+https://github.com/jrfonseca/drmingw.git#tag=${pkgver}"
        '001-Add-MSYS-cmake-guard.patch'
        '002-install-files.patch'
        '003-drmingw-allow-posix-threads.patch'
        '004-Comment-out-mgwhelp-POST_BUILD.patch'
        '005-Comment-out-catchsegv-POST_BUILD.patch')
sha256sums=('ba5b2e99d1e215ddfbc9fc038e77901a705fcbf7a8b241c0bd40c4ea636df431'
            'd30cba7ada8dcc995f135b9ce755cab7fb9fd40ee56ac876b643514672f3e1bc'
            '14b86049462b5c2ac505f4fbde1a49386ad918fd596e1c6d62bde5831eff15e6'
            '4faa655ed0edc371e64565fcd9e801fda59fd28150cf5b62a566927fa53e4144'
            '2ee7ae24a784f0747b40073bf84903a4a3b596955067bbc80258aabea6ab85fb'
            'da8a57e6adfdf229c7da586df1e884cb95c3ffe55eab92a1d3a1343691e4c5d2')

prepare() {
  cd "${srcdir}/${_realname}"
  git submodule update --init --depth=1
  git apply "${srcdir}/001-Add-MSYS-cmake-guard.patch"
  git apply "${srcdir}/002-install-files.patch"
  git apply "${srcdir}/003-drmingw-allow-posix-threads.patch"
  git apply "${srcdir}/004-Comment-out-mgwhelp-POST_BUILD.patch"
  git apply "${srcdir}/005-Comment-out-catchsegv-POST_BUILD.patch"
}

build() {
  mkdir -p "${srcdir}"/build-${MSYSTEM_CARCH} && cd "${srcdir}"/build-${MSYSTEM_CARCH}

  export CC="/usr/bin/${MSYSTEM_CARCH}-w64-mingw32-gcc"
  export CXX="/usr/bin/${MSYSTEM_CARCH}-w64-mingw32-g++"
  export LD="/usr/bin/${MSYSTEM_CARCH}-w64-mingw32-ld"
  export RC="/usr/bin/${MSYSTEM_CARCH}-w64-mingw32-windres"

  ${MSYSTEM_PREFIX}/bin/cmake.exe \
    -G"Ninja" \
    -DCMAKE_INSTALL_PREFIX=${MSYSTEM_PREFIX} \
    -DCMAKE_SYSTEM_NAME='Windows' \
    ../${_realname}

  ${MSYSTEM_PREFIX}/bin/cmake.exe --build ./
}

check() {
  cd "${srcdir}/build-${MSYSTEM_CARCH}"
  ${MSYSTEM_PREFIX}/bin/ctest.exe ./ || true
}

package() {
  cd "${srcdir}/build-${MSYSTEM_CARCH}"

  DESTDIR="${pkgdir}" ${MSYSTEM_PREFIX}/bin/cmake.exe --install .

  mv -v "${pkgdir}"${MSYSTEM_PREFIX}/bin/addr2line{,-drmingw}.exe

  mkdir -p "${pkgdir}"${MSYSTEM_PREFIX}/share/licenses/${_realname}
  mv -v "${pkgdir}"${MSYSTEM_PREFIX}/share/doc/${_realname}/LICENSE* \
    "${pkgdir}"${MSYSTEM_PREFIX}/share/licenses/${_realname}/
}
